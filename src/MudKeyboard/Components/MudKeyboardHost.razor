@namespace MudKeyboard.Components
@using Microsoft.JSInterop
@implements IDisposable
@inject KeyboardInteropService Interop

@* The dock's styles ship as a plain static asset (wwwroot/MudKeyboard.css), not Blazor scoped CSS,
   so the library never forces the consuming app to build its "{AppName}.styles.css" bundle. The host
   pulls the sheet in itself via this <link>, so callers need no extra setup. A stylesheet <link> in
   the body is valid HTML5 ("body-ok") and applies the same as one in <head>; it renders once because
   the host is placed once. *@
<link rel="stylesheet" href="_content/MudKeyboard/MudKeyboard.css" />

@* Optional dimming backdrop behind the dock (opt-in via ShowBackdrop). Rendered just below the dock
   in z-order and only while the panel is open. A click cancels the edit (reverts to the value the
   field had at focus-in) unless DisableBackdropClick is set, in which case it does nothing and a
   Cancel button is shown in the preview bar instead. mousedown:preventDefault keeps the focused field
   focused so the cancel/revert logic — not a stray blur — controls the close. *@
@if (ShowBackdrop && Interop.IsOpen)
{
    <div class="mudkeyboard-backdrop"
         style="z-index:@DockZIndex"
         @onmousedown:preventDefault="true"
         @onclick="HandleBackdropClickAsync"
         aria-hidden="true"></div>
}

@* Place ONCE in your layout. The container is always present (off-screen) so the slide-up
   transition animates whenever the --open class is toggled; the keyboard inside it renders once a
   field is focused. mousedown:preventDefault keeps the focused field focused while keys are tapped,
   so the caret stays put and the panel does not close on key presses. *@
@* While closed the panel sits off-screen but is still in the DOM, so its keys/toolbar would otherwise
   stay in the tab order and accessibility tree. `inert` removes them from focus and pointer interaction,
   and `aria-hidden` hides them from screen readers, until a field is focused and the dock opens. Both
   clear automatically when open. *@
<div class="mudkeyboard-dock @(Interop.IsOpen ? "mudkeyboard-dock--open" : null) @DockSizeClass"
     style="z-index:@DockZIndex"
     @onmousedown:preventDefault="true"
     role="group"
     aria-label="On-screen keyboard"
     aria-hidden="@(Interop.IsOpen ? null : "true")"
     inert="@(!Interop.IsOpen)">
    @if (Interop.CurrentLayout is not null)
    {
        <MudPaper Elevation="@Elevation"
                  Class="pa-2"
                  Style="@PanelStyle">
            @* Value-preview / edit bar (opt-in via ShowValuePreview). Shows the focused field's live
               value at the top of the keyboard so the user can see what they are editing; the keys edit
               it live and Cancel reverts. aria-live announces value changes to assistive tech. The
               Cancel button appears only when the backdrop click is disabled (DisableBackdropClick),
               since otherwise the backdrop click already provides a way to cancel. *@
            @if (ShowValuePreview)
            {
                <div class="mudkeyboard-dock__preview" role="status" aria-live="polite" aria-label="Current value">
                    <span class="mudkeyboard-dock__preview-text">@Interop.CurrentValue</span>
                    @if (ShowCancelButton)
                    {
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   Class="mudkeyboard-dock__cancel"
                                   OnClick="@CancelAsync"
                                   aria-label="Cancel and revert">@CancelLabel</MudButton>
                    }
                </div>
            }
            @* Toolbar labels use the native title attribute rather than MudTooltip. MudTooltip needs a
               MudPopoverProvider in scope, but this host is designed to be placed in its own interactive
               island (in App.razor, outside <Routes>) so the docked keyboard works on static-SSR pages —
               where no MudBlazor providers are ancestors. A native title keeps the host self-contained and
               dependency-free; every button still carries an aria-label for assistive tech. *@
            @* The toolbar renders only the buttons the consumer left in VisibleActions; any in
               DisabledActions render greyed-out. When VisibleActions is None the whole bar is dropped so
               no empty role="toolbar" lingers in the accessibility tree. *@
            @if (VisibleActions != KeyboardAction.None)
            {
                <div class="mudkeyboard-dock__bar" role="toolbar" aria-label="Keyboard actions">
                    <div class="mudkeyboard-dock__tools">
                        @if (IsActionVisible(KeyboardAction.Clear))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Medium"
                                           Disabled="@IsActionDisabled(KeyboardAction.Clear)"
                                           OnClick="@ClearAsync"
                                           title="Clear"
                                           aria-label="Clear field" />
                        }
                        @if (IsActionVisible(KeyboardAction.Copy))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                           Size="Size.Medium"
                                           Disabled="@IsActionDisabled(KeyboardAction.Copy)"
                                           OnClick="@CopyAsync"
                                           title="Copy"
                                           aria-label="Copy" />
                        }
                        @if (IsActionVisible(KeyboardAction.Paste))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.ContentPaste"
                                           Size="Size.Medium"
                                           Disabled="@IsActionDisabled(KeyboardAction.Paste)"
                                           OnClick="@PasteAsync"
                                           title="Paste"
                                           aria-label="Paste" />
                        }
                        @* Cursor arrows are meaningless for pence-first money entry (always appends at the end). *@
                        @if (!IsMoney && IsActionVisible(KeyboardAction.CursorLeft))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                           Size="Size.Medium"
                                           Disabled="@IsActionDisabled(KeyboardAction.CursorLeft)"
                                           OnClick="@(() => MoveCaretAsync(-1))"
                                           title="Move cursor left"
                                           aria-label="Move cursor left" />
                        }
                        @if (!IsMoney && IsActionVisible(KeyboardAction.CursorRight))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                           Size="Size.Medium"
                                           Disabled="@IsActionDisabled(KeyboardAction.CursorRight)"
                                           OnClick="@(() => MoveCaretAsync(1))"
                                           title="Move cursor right"
                                           aria-label="Move cursor right" />
                        }
                    </div>
                    @if (IsActionVisible(KeyboardAction.Hide))
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                                       Size="Size.Medium"
                                       Disabled="@IsActionDisabled(KeyboardAction.Hide)"
                                       OnClick="@HideAsync"
                                       title="Hide keyboard"
                                       aria-label="Hide keyboard" />
                    }
                </div>
            }
            <MudKeyboard Layout="Interop.CurrentLayout"
                         SymbolLayout="Interop.CurrentSymbolLayout"
                         Palette="Palette"
                         DropShadow="false"
                         Sound="@Sound"
                         SoundSrc="@SoundSrc"
                         AriaLabel="Keyboard keys"
                         OnInput="@HandleInputAsync" />
        </MudPaper>
    }
</div>

@code { 

    /// <summary>Optional colour overrides for the docked keyboard. See <see cref="KeyboardPalette"/>.</summary>
    [Parameter] public KeyboardPalette? Palette { get; set; }

    /// <summary>Elevation (drop shadow) of the docked panel. Default <c>8</c>.</summary>
    [Parameter] public int Elevation { get; set; } = 8;

    /// <summary>
    /// Floor for the docked keyboard's <c>z-index</c>. On every open the keyboard measures the highest
    /// z-index on the page and docks <em>one above it</em>, so it always floats over the current top-most
    /// layer (a dialog, a nested dialog, a custom overlay at any value). This value only kicks in when the
    /// page has nothing higher — it guarantees a sensible minimum. Default <c>1400</c>.
    /// </summary>
    [Parameter] public int MinZIndex { get; set; } = 1400;

    /// <summary>Extra inline styles appended to the docked panel.</summary>
    [Parameter] public string? Style { get; set; }

    /// <summary>
    /// Which toolbar action buttons the docked keyboard renders (Clear, Copy, Paste, the cursor arrows and
    /// Hide). A <see cref="FlagsAttribute"/> set: combine members with <c>|</c> and remove them with
    /// <c>&amp; ~</c>. Default <see cref="KeyboardAction.All"/>; set to <see cref="KeyboardAction.None"/> to
    /// drop the whole toolbar. The cursor arrows never show on the money keypad regardless of this value,
    /// because pence-first entry always appends at the end.
    /// </summary>
    [Parameter] public KeyboardAction VisibleActions { get; set; } = KeyboardAction.All;

    /// <summary>
    /// Which toolbar action buttons render greyed-out and non-interactive. A <see cref="FlagsAttribute"/>
    /// set. Default <see cref="KeyboardAction.None"/>. Hiding wins over disabling: a button absent from
    /// <see cref="VisibleActions"/> is not rendered at all, whether or not it appears here.
    /// </summary>
    [Parameter] public KeyboardAction DisabledActions { get; set; } = KeyboardAction.None;

    /// <summary>
    /// Default for whether numeric keypads (number, decimal and money) show a <c>±</c> sign-toggle key so
    /// negative values can be entered. Default <see langword="false"/>. A field can override this per field
    /// with a <c>data-mudkeyboard-allow-negative</c> attribute (which <c>MudKeyboardNumericField.AllowNegative</c>
    /// emits).
    /// </summary>
    [Parameter] public bool AllowNegative { get; set; }

    /// <summary>
    /// When <see langword="true"/>, the docked keyboard shows a value-preview bar at the top displaying the
    /// focused field's live value, so the user can see exactly what they are editing. The keys edit it live;
    /// a Cancel button or a backdrop click reverts to the value the field had when it was focused. Default
    /// <see langword="false"/>.
    /// </summary>
    [Parameter] public bool ShowValuePreview { get; set; }

    /// <summary>
    /// When <see langword="true"/>, a dimming backdrop is shown behind the docked keyboard while it is open.
    /// Clicking it cancels the edit (reverts to the focused field's value at focus-in) and closes the
    /// keyboard — unless <see cref="DisableBackdropClick"/> is set. Default <see langword="false"/>.
    /// </summary>
    [Parameter] public bool ShowBackdrop { get; set; }

    /// <summary>
    /// When <see langword="true"/>, clicking the backdrop no longer dismisses the keyboard; instead a
    /// <strong>Cancel</strong> button is shown in the value-preview bar (so <see cref="ShowValuePreview"/>
    /// must also be set for the button to appear). Use this when you want the docked keyboard to stay open
    /// until the user explicitly confirms (Enter / Hide) or cancels. Default <see langword="false"/>.
    /// </summary>
    [Parameter] public bool DisableBackdropClick { get; set; }

    /// <summary>Text for the Cancel button shown in the value-preview bar. Default <c>"Cancel"</c>.</summary>
    [Parameter] public string CancelLabel { get; set; } = "Cancel";

    /// <summary>
    /// When <see langword="true"/>, the docked keyboard plays a short click sound on every key press,
    /// rendered via a Blazor <c>&lt;audio&gt;</c> element (no JavaScript). Default <see langword="false"/>.
    /// </summary>
    [Parameter] public bool Sound { get; set; }

    /// <summary>
    /// Optional source for the click sound (any URL or <c>data:</c> URI). When unset the built-in
    /// synthesised click is used. Ignored unless <see cref="Sound"/> is set.
    /// </summary>
    [Parameter] public string? SoundSrc { get; set; }

    private string PanelStyle => $"border-radius:16px 16px 0 0;{Style}";

    // The Cancel button only makes sense when the preview bar exists and the backdrop click is disabled —
    // otherwise a backdrop click already cancels, or there is no preview bar to host the button.
    private bool ShowCancelButton => ShowValuePreview && DisableBackdropClick;

    private bool IsActionVisible(KeyboardAction action) => (VisibleActions & action) != 0;

    private bool IsActionDisabled(KeyboardAction action) => (DisabledActions & action) != 0;

    // Sit one above the highest layer on the page when opened (e.g. a dialog), but never below the floor.
    private int DockZIndex => Math.Max(Interop.PageMaxZIndex + 1, MinZIndex);

    // The numeric/money keypads are the built-in numpad layouts (signed or not); everything else is text.
    private bool IsKeypad => LayoutLibrary.IsKeypad(Interop.CurrentLayout);

    // The money keypad enters digits pence-first (no decimal-point key) like MudPricepad.
    private bool IsMoney => LayoutLibrary.IsMoney(Interop.CurrentLayout);

    // Drives the dock width: a roomier panel for the full keyboard, a narrower one for keypads.
    private string DockSizeClass => IsKeypad ? "mudkeyboard-dock--keypad" : "mudkeyboard-dock--text";

    protected override void OnInitialized() => Interop.StateChanged += OnStateChanged;

    // Propagate host-level defaults to the interop service: the AllowNegative default for focused fields
    // without a data-mudkeyboard-allow-negative attribute, and whether the JS shim should report value
    // changes back so the preview bar can mirror the field live.
    protected override void OnParametersSet()
    {
        Interop.AllowNegativeDefault = AllowNegative;
        Interop.ReportValueChanges = ShowValuePreview;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // JS interop is only available once the component is interactive. During static SSR
        // prerendering OnAfterRenderAsync does not run on the server at all, so the focus-capture
        // module is never imported until the host hydrates in the browser. That is exactly what lets
        // the docked keyboard work on static-SSR pages: place this host in its own interactive island
        // (e.g. in App.razor, OUTSIDE <Routes>) and it stays live regardless of any page's render mode.
        //
        // The try/catch is a belt-and-braces guard. If the JS runtime is not yet available (a stray
        // prerender pass throws InvalidOperationException) or the circuit has already gone
        // (JSDisconnectedException, a subtype of JSException), the host silently does nothing instead
        // of throwing.
        //
        // Note: we intentionally do NOT detect prerendering via a [CascadingParameter] HttpContext.
        // HttpContext lives in the ASP.NET Core shared framework; depending on it would break this
        // WebAssembly-friendly, AOT/trim-safe library for WASM consumers. Guarding the interop call is
        // render-mode- and framework-agnostic and works identically on net8.0, net9.0 and net10.0.
        if (firstRender)
        {
            try
            {
                await Interop.InitializeAsync();
            }
            catch (JSException)
            {
                // JS runtime unavailable / module failed to load (e.g. prerender, disconnected circuit).
            }
            catch (InvalidOperationException)
            {
                // "JavaScript interop calls cannot be issued at this time" — still statically rendering.
            }
        }
    }

    private async Task HandleInputAsync(KeyboardInput input)
    {
        switch (input.Kind)
        {
            case KeyboardInputKind.Text:
                if (IsMoney)
                {
                    await Interop.AppendMoneyDigitsAsync(input.Text);
                }
                else
                {
                    await Interop.InsertTextAsync(input.Text);
                }

                break;
            case KeyboardInputKind.Backspace:
                if (IsMoney)
                {
                    await Interop.BackspaceMoneyAsync();
                }
                else
                {
                    await Interop.BackspaceAsync();
                }

                break;
            case KeyboardInputKind.Sign:
                if (IsMoney)
                {
                    await Interop.ToggleMoneySignAsync();
                }
                else
                {
                    await Interop.ToggleSignAsync();
                }

                break;
            case KeyboardInputKind.Enter:
                // Enter commits, then closes the keyboard for every layout.
                await Interop.EnterAsync();
                await Interop.CloseAsync();
                break;
            case KeyboardInputKind.Escape:
                await Interop.CloseAsync();
                break;
        }
    }

    private Task HideAsync() => Interop.CloseAsync();

    // Cancel the edit: revert the focused field to its value at focus-in and close. Used by both the
    // Cancel button and an (enabled) backdrop click.
    private Task CancelAsync() => Interop.CancelAsync();

    // A backdrop click cancels unless the consumer disabled it (in which case the Cancel button is shown).
    private Task HandleBackdropClickAsync() => DisableBackdropClick ? Task.CompletedTask : CancelAsync();

    private Task ClearAsync() => Interop.ClearAsync().AsTask();

    private Task CopyAsync() => Interop.CopyAsync().AsTask();

    private Task PasteAsync() => Interop.PasteAsync().AsTask();

    private Task MoveCaretAsync(int delta) => Interop.MoveCaretAsync(delta).AsTask();

    // Focus events arrive from JS; marshal the re-render onto the renderer's sync context.
    private void OnStateChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => Interop.StateChanged -= OnStateChanged;
}
