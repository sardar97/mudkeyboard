@namespace MudKeyboard.Components
@using Microsoft.JSInterop
@implements IDisposable
@inject KeyboardInteropService Interop

@* The dock's styles ship as a plain static asset (wwwroot/MudKeyboard.css), not Blazor scoped CSS,
   so the library never forces the consuming app to build its "{AppName}.styles.css" bundle. The host
   pulls the sheet in itself via this <link>, so callers need no extra setup. A stylesheet <link> in
   the body is valid HTML5 ("body-ok") and applies the same as one in <head>; it renders once because
   the host is placed once. *@
<link rel="stylesheet" href="_content/MudKeyboard/MudKeyboard.css" />

@* Place ONCE in your layout. The container is always present (off-screen) so the slide-up
   transition animates whenever the --open class is toggled; the keyboard inside it renders once a
   field is focused. mousedown:preventDefault keeps the focused field focused while keys are tapped,
   so the caret stays put and the panel does not close on key presses. *@
<div class="mudkeyboard-dock @(Interop.IsOpen ? "mudkeyboard-dock--open" : null) @DockSizeClass"
     style="z-index:@DockZIndex"
     @onmousedown:preventDefault="true"
     role="group"
     aria-label="On-screen keyboard">
    @if (Interop.CurrentLayout is not null)
    {
        <MudPaper Elevation="@Elevation"
                  Class="pa-2"
                  Style="@PanelStyle">
            @* Toolbar labels use the native title attribute rather than MudTooltip. MudTooltip needs a
               MudPopoverProvider in scope, but this host is designed to be placed in its own interactive
               island (in App.razor, outside <Routes>) so the docked keyboard works on static-SSR pages —
               where no MudBlazor providers are ancestors. A native title keeps the host self-contained and
               dependency-free; every button still carries an aria-label for assistive tech. *@
            <div class="mudkeyboard-dock__bar">
                <div class="mudkeyboard-dock__tools">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Medium"
                                   OnClick="@ClearAsync"
                                   title="Clear"
                                   aria-label="Clear field" />
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                   Size="Size.Medium"
                                   OnClick="@CopyAsync"
                                   title="Copy"
                                   aria-label="Copy" />
                    <MudIconButton Icon="@Icons.Material.Filled.ContentPaste"
                                   Size="Size.Medium"
                                   OnClick="@PasteAsync"
                                   title="Paste"
                                   aria-label="Paste" />
                    @* Cursor arrows are meaningless for pence-first money entry (always appends at the end). *@
                    @if (!IsMoney)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                       Size="Size.Medium"
                                       OnClick="@(() => MoveCaretAsync(-1))"
                                       title="Move cursor left"
                                       aria-label="Move cursor left" />
                        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                       Size="Size.Medium"
                                       OnClick="@(() => MoveCaretAsync(1))"
                                       title="Move cursor right"
                                       aria-label="Move cursor right" />
                    }
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                               Size="Size.Medium"
                               OnClick="@HideAsync"
                               title="Hide keyboard"
                               aria-label="Hide keyboard" />
            </div>
            <MudKeyboard Layout="Interop.CurrentLayout"
                         SymbolLayout="Interop.CurrentSymbolLayout"
                         Palette="Palette"
                         DropShadow="false"
                         OnInput="@HandleInputAsync" />
        </MudPaper>
    }
</div>

@code { 

    /// <summary>Optional colour overrides for the docked keyboard. See <see cref="KeyboardPalette"/>.</summary>
    [Parameter] public KeyboardPalette? Palette { get; set; }

    /// <summary>Elevation (drop shadow) of the docked panel. Default <c>8</c>.</summary>
    [Parameter] public int Elevation { get; set; } = 8;

    /// <summary>
    /// Floor for the docked keyboard's <c>z-index</c>. On every open the keyboard measures the highest
    /// z-index on the page and docks <em>one above it</em>, so it always floats over the current top-most
    /// layer (a dialog, a nested dialog, a custom overlay at any value). This value only kicks in when the
    /// page has nothing higher — it guarantees a sensible minimum. Default <c>1400</c>.
    /// </summary>
    [Parameter] public int MinZIndex { get; set; } = 1400;

    /// <summary>Extra inline styles appended to the docked panel.</summary>
    [Parameter] public string? Style { get; set; }

    private string PanelStyle => $"border-radius:16px 16px 0 0;{Style}";

    // Sit one above the highest layer on the page when opened (e.g. a dialog), but never below the floor.
    private int DockZIndex => Math.Max(Interop.PageMaxZIndex + 1, MinZIndex);

    // The numeric/money keypads are the built-in numpad layouts; everything else (QWERTY, custom) is text.
    private bool IsKeypad =>
        ReferenceEquals(Interop.CurrentLayout, LayoutLibrary.Numpad)
        || ReferenceEquals(Interop.CurrentLayout, LayoutLibrary.NumpadWithDecimal)
        || ReferenceEquals(Interop.CurrentLayout, LayoutLibrary.Price);

    // The money keypad enters digits pence-first (no decimal-point key) like MudPricepad.
    private bool IsMoney => ReferenceEquals(Interop.CurrentLayout, LayoutLibrary.Price);

    // Drives the dock width: a roomier panel for the full keyboard, a narrower one for keypads.
    private string DockSizeClass => IsKeypad ? "mudkeyboard-dock--keypad" : "mudkeyboard-dock--text";

    protected override void OnInitialized() => Interop.StateChanged += OnStateChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // JS interop is only available once the component is interactive. During static SSR
        // prerendering OnAfterRenderAsync does not run on the server at all, so the focus-capture
        // module is never imported until the host hydrates in the browser. That is exactly what lets
        // the docked keyboard work on static-SSR pages: place this host in its own interactive island
        // (e.g. in App.razor, OUTSIDE <Routes>) and it stays live regardless of any page's render mode.
        //
        // The try/catch is a belt-and-braces guard. If the JS runtime is not yet available (a stray
        // prerender pass throws InvalidOperationException) or the circuit has already gone
        // (JSDisconnectedException, a subtype of JSException), the host silently does nothing instead
        // of throwing.
        //
        // Note: we intentionally do NOT detect prerendering via a [CascadingParameter] HttpContext.
        // HttpContext lives in the ASP.NET Core shared framework; depending on it would break this
        // WebAssembly-friendly, AOT/trim-safe library for WASM consumers. Guarding the interop call is
        // render-mode- and framework-agnostic and works identically on net8.0, net9.0 and net10.0.
        if (firstRender)
        {
            try
            {
                await Interop.InitializeAsync();
            }
            catch (JSException)
            {
                // JS runtime unavailable / module failed to load (e.g. prerender, disconnected circuit).
            }
            catch (InvalidOperationException)
            {
                // "JavaScript interop calls cannot be issued at this time" — still statically rendering.
            }
        }
    }

    private async Task HandleInputAsync(KeyboardInput input)
    {
        switch (input.Kind)
        {
            case KeyboardInputKind.Text:
                if (IsMoney)
                {
                    await Interop.AppendMoneyDigitsAsync(input.Text);
                }
                else
                {
                    await Interop.InsertTextAsync(input.Text);
                }

                break;
            case KeyboardInputKind.Backspace:
                if (IsMoney)
                {
                    await Interop.BackspaceMoneyAsync();
                }
                else
                {
                    await Interop.BackspaceAsync();
                }

                break;
            case KeyboardInputKind.Enter:
                // Enter commits, then closes the keyboard for every layout.
                await Interop.EnterAsync();
                await Interop.CloseAsync();
                break;
            case KeyboardInputKind.Escape:
                await Interop.CloseAsync();
                break;
        }
    }

    private Task HideAsync() => Interop.CloseAsync();

    private Task ClearAsync() => Interop.ClearAsync().AsTask();

    private Task CopyAsync() => Interop.CopyAsync().AsTask();

    private Task PasteAsync() => Interop.PasteAsync().AsTask();

    private Task MoveCaretAsync(int delta) => Interop.MoveCaretAsync(delta).AsTask();

    // Focus events arrive from JS; marshal the re-render onto the renderer's sync context.
    private void OnStateChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => Interop.StateChanged -= OnStateChanged;
}
