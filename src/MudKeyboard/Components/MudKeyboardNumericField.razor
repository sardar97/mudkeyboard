@namespace MudKeyboard.Components
@using System.Linq.Expressions
@typeparam T

@* A thin, generic wrapper around MudNumericField<T> that makes the global docked keyboard show the
   right keypad for the field's CLR type — without the caller having to remember any data-* attribute:

     • T = decimal          → the money keypad (currency, pence-first entry)
     • T = double / float   → the numeric keypad WITH a "." key
     • T = int / long / …   → the numeric keypad WITHOUT a "." key

   A decimal and a double render the same HTML (inputmode="decimal"), so the focus-capture shim cannot
   tell money from a plain decimal on its own — only the bound type can. This wrapper resolves the
   layout from T (see NumericLayoutResolver) and splats data-mudkeyboard-layout onto the underlying
   <input>, which is the element the shim watches. Set DockedKeyboardLayout to override the choice. No
   reflection over members is used, so it stays AOT/trim friendly. *@
<MudNumericField T="T"
                 Value="Value"
                 ValueChanged="OnValueChanged"
                 For="@For"
                 Label="@Label"
                 Placeholder="@Placeholder"
                 HelperText="@HelperText"
                 Variant="Variant"
                 Margin="Margin"
                 Adornment="Adornment"
                 AdornmentIcon="@AdornmentIcon"
                 Immediate="Immediate"
                 Disabled="Disabled"
                 ReadOnly="ReadOnly"
                 ShrinkLabel="ShrinkLabel"
                 Format="@Format"
                 Class="@Class"
                 Style="@Style"
                 @attributes="BuildForwardedAttributes()" />

@code {
    /// <summary>The field value, two-way bindable via <c>@bind-Value</c>.</summary>
    [Parameter] public T? Value { get; set; }

    /// <summary>Raised when <see cref="Value"/> changes.</summary>
    [Parameter] public EventCallback<T> ValueChanged { get; set; }

    // Forward the inner field's value change through this wrapper's own two-way binding. Keeping the
    // local Value in step (as well as re-invoking ValueChanged) is the robust wrapper pattern — a bare
    // ValueChanged="@ValueChanged" forward does not reliably propagate MudNumericField's changes.
    private async Task OnValueChanged(T value)
    {
        Value = value;
        await ValueChanged.InvokeAsync(value);
    }

    /// <summary>Validation expression for the bound value (for example <c>@(() =&gt; Model.Price)</c>).</summary>
    [Parameter] public Expression<Func<T>>? For { get; set; }

    /// <summary>The field label.</summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>Placeholder text shown while the field is empty.</summary>
    [Parameter] public string? Placeholder { get; set; }

    /// <summary>Helper text shown beneath the field.</summary>
    [Parameter] public string? HelperText { get; set; }

    /// <summary>The MudBlazor input variant. Default <see cref="MudBlazor.Variant.Text"/>.</summary>
    [Parameter] public Variant Variant { get; set; } = Variant.Text;

    /// <summary>The field's margin. Default <see cref="MudBlazor.Margin.None"/>.</summary>
    [Parameter] public Margin Margin { get; set; } = Margin.None;

    /// <summary>Where to place the adornment, if any. Default <see cref="MudBlazor.Adornment.None"/>.</summary>
    [Parameter] public Adornment Adornment { get; set; } = Adornment.None;

    /// <summary>The adornment icon, used when <see cref="Adornment"/> is set (for example a currency icon).</summary>
    [Parameter] public string? AdornmentIcon { get; set; }

    /// <summary>When <see langword="true"/>, the bound value updates on every keystroke. Default <see langword="false"/>.</summary>
    [Parameter] public bool Immediate { get; set; }

    /// <summary>Disables the field.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Makes the field read-only.</summary>
    [Parameter] public bool ReadOnly { get; set; }

    /// <summary>When <see langword="true"/>, the label stays shrunk above the field even when it is empty.</summary>
    [Parameter] public bool ShrinkLabel { get; set; }

    /// <summary>The .NET numeric format string applied to the value (for example <c>"N2"</c>).</summary>
    [Parameter] public string? Format { get; set; }

    /// <summary>Optional minimum value. Only applied when explicitly set.</summary>
    [Parameter] public T? Min { get; set; }

    /// <summary>Optional maximum value. Only applied when explicitly set.</summary>
    [Parameter] public T? Max { get; set; }

    /// <summary>Optional step applied by the spin buttons / arrow keys. Only applied when explicitly set.</summary>
    [Parameter] public T? Step { get; set; }

    // Whether the caller actually supplied Min / Max / Step. For a value-type T (decimal, int, …) the
    // nullable parameters above are NOT Nullable<T>; they default to default(T) (e.g. 0). Forwarding that
    // default unconditionally would make MudNumericField treat it as a real bound and clamp every entered
    // value to it (the classic "the field snaps back to 0" bug). So we forward each only when set.
    private bool _minSet;
    private bool _maxSet;
    private bool _stepSet;

    // Whether the caller explicitly set AllowNegative. Only then is data-mudkeyboard-allow-negative emitted,
    // so that leaving it unset lets the host's global MudKeyboardHost.AllowNegative default apply, while
    // setting it to either true or false overrides that default for this field.
    private bool _allowNegativeSet;

    /// <inheritdoc />
    public override Task SetParametersAsync(ParameterView parameters)
    {
        _minSet = _maxSet = _stepSet = _allowNegativeSet = false;
        foreach (var parameter in parameters)
        {
            switch (parameter.Name)
            {
                case nameof(Min): _minSet = true; break;
                case nameof(Max): _maxSet = true; break;
                case nameof(Step): _stepSet = true; break;
                case nameof(AllowNegative): _allowNegativeSet = true; break;
            }
        }

        return base.SetParametersAsync(parameters);
    }

    /// <summary>Extra CSS classes for the field.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Extra inline styles for the field.</summary>
    [Parameter] public string? Style { get; set; }

    /// <summary>
    /// When <see langword="true"/>, emits <c>data-mudkeyboard="true"</c> so the global
    /// <see cref="MudKeyboardHost"/> raises the docked keyboard for this field. This is required when the
    /// host runs in <see cref="KeyboardAttachMode.OptIn"/> mode. In the default <c>AllInputs</c> mode the
    /// field attaches anyway. Default <see langword="false"/>.
    /// </summary>
    [Parameter] public bool DockedKeyboard { get; set; }

    /// <summary>
    /// Overrides the docked-keyboard layout for this field by emitting an explicit
    /// <c>data-mudkeyboard-layout</c> — for example <c>"money"</c>, <c>"decimal"</c>, <c>"numpad"</c> or
    /// <c>"qwerty"</c>. Left empty (the default), the layout is resolved automatically from
    /// <typeparamref name="T"/>: <see cref="decimal"/> → money, <see cref="double"/>/<see cref="float"/> →
    /// decimal keypad, integer types → plain numpad.
    /// </summary>
    [Parameter] public string DockedKeyboardLayout { get; set; } = string.Empty;

    /// <summary>
    /// When <see langword="true"/>, the docked numeric keypad for this field shows a <c>±</c> sign-toggle
    /// key (emitting <c>data-mudkeyboard-allow-negative="true"</c>) so negative values can be entered.
    /// Default <see langword="false"/>. Overrides the global <see cref="MudKeyboardHost.AllowNegative"/>.
    /// </summary>
    [Parameter] public bool AllowNegative { get; set; }

    /// <summary>
    /// Any additional attributes (for example <c>name</c>, <c>autocomplete</c>) or extra
    /// <see cref="MudNumericField{T}"/> parameters not surfaced above are forwarded to the underlying
    /// field and onto its input element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? UserAttributes { get; set; }

    // The layout token sent to the docked keyboard: an explicit override wins, otherwise it is resolved
    // from T (decimal → money, double/float → decimal keypad, integers → numpad).
    private string ResolvedLayout =>
        string.IsNullOrEmpty(DockedKeyboardLayout)
            ? NumericLayoutResolver.Resolve(typeof(T))
            : DockedKeyboardLayout;

    // Merge caller-supplied attributes with the docked-keyboard markers and any explicitly-set
    // Min/Max/Step, then splat the result onto MudNumericField. MudBlazor binds the keys that match its
    // parameters (Min/Max/Step) and forwards the rest (data-mudkeyboard-*, name, …) to the real <input> —
    // the element the focus-capture shim watches. The layout marker is always emitted so the correct
    // keypad shows in AllInputs mode with no extra configuration.
    private Dictionary<string, object> BuildForwardedAttributes()
    {
        var attributes = UserAttributes is null
            ? new Dictionary<string, object>()
            : new Dictionary<string, object>(UserAttributes);

        if (DockedKeyboard)
        {
            attributes["data-mudkeyboard"] = "true";
        }

        attributes["data-mudkeyboard-layout"] = ResolvedLayout;

        // Emit the negative opt-in only when explicitly set, so the host's global default applies otherwise.
        if (_allowNegativeSet)
        {
            attributes["data-mudkeyboard-allow-negative"] = AllowNegative ? "true" : "false";
        }

        // Forward numeric bounds only when the caller set them (see _minSet/_maxSet/_stepSet above).
        if (_minSet && Min is not null)
        {
            attributes[nameof(Min)] = Min;
        }

        if (_maxSet && Max is not null)
        {
            attributes[nameof(Max)] = Max;
        }

        if (_stepSet && Step is not null)
        {
            attributes[nameof(Step)] = Step;
        }

        return attributes;
    }
}
