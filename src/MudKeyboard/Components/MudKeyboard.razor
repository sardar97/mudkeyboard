@namespace MudKeyboard.Components

<MudPaper Class="@Class" Style="@KeyboardPalette.Compose(Palette, Style)" Elevation="0"
          role="group" aria-label="@EffectiveAriaLabel">
    <KeyGrid Keys="@_displayKeys" Disabled="Disabled" DropShadow="@DropShadow" Sound="@Sound" SoundSrc="@SoundSrc" OnKeyPress="@HandleKeyPressAsync" OnKeyDoublePress="@HandleDoublePress" />
</MudPaper>

@code {
    private KeyboardLayout? _baseLayout;
    private KeyboardLayout? _symbolLayout;
    private IReadOnlyList<IReadOnlyList<KeyboardKey>> _displayKeys = [];
    private ShiftState _shiftState = ShiftState.Off;
    private bool _symbolMode;

    /// <summary>The current value, two-way bindable via <c>@bind-Value</c>.</summary>
    [Parameter] public string Value { get; set; } = string.Empty;

    /// <summary>Raised when <see cref="Value"/> changes.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>An explicit layout. When set, it overrides <see cref="Variant"/>.</summary>
    [Parameter] public KeyboardLayout? Layout { get; set; }

    /// <summary>Which built-in surface to show when <see cref="Layout"/> is not set. Default <see cref="KeyboardVariant.Full"/>.</summary>
    [Parameter] public KeyboardVariant Variant { get; set; } = KeyboardVariant.Full;

    /// <summary>
    /// The numbers/symbols face shown when a <see cref="KeyTokens.SymbolToggle"/> (<c>{sym}</c>)
    /// key is pressed. When not set it defaults to the built-in symbol face for <see cref="Variant"/>
    /// (only <see cref="KeyboardVariant.Full"/> has one). Supply this to give a custom
    /// <see cref="Layout"/> its own symbol face.
    /// </summary>
    [Parameter] public KeyboardLayout? SymbolLayout { get; set; }

    /// <summary>Optional maximum length of <see cref="Value"/>.</summary>
    [Parameter] public int? MaxLength { get; set; }

    /// <summary>Disables every key.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Whether the keys cast a drop shadow. Set <see langword="false"/> for flat keys. Default <see langword="true"/>.</summary>
    [Parameter] public bool DropShadow { get; set; } = true;

    /// <summary>
    /// When <see langword="true"/>, a short click sound plays on every key press. Played via a
    /// Blazor-rendered <c>&lt;audio&gt;</c> element — no JavaScript — so it works in every render mode.
    /// Default <see langword="false"/>.
    /// </summary>
    [Parameter] public bool Sound { get; set; }

    /// <summary>
    /// Optional source for the click sound (any URL or <c>data:</c> URI). When unset the built-in
    /// synthesised click is used. Ignored unless <see cref="Sound"/> is set.
    /// </summary>
    [Parameter] public string? SoundSrc { get; set; }

    /// <summary>Extra CSS classes for the root element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Extra inline styles for the root element.</summary>
    [Parameter] public string? Style { get; set; }

    /// <summary>
    /// Accessible name for the keyboard, applied to the root <c>role="group"</c> as its
    /// <c>aria-label</c> so assistive technology can announce the control. Default
    /// <c>"On-screen keyboard"</c>.
    /// </summary>
    [Parameter] public string? AriaLabel { get; set; }

    private string EffectiveAriaLabel => string.IsNullOrWhiteSpace(AriaLabel) ? "On-screen keyboard" : AriaLabel;

    /// <summary>
    /// Optional colour overrides for this keyboard. Unset slots inherit the ambient MudBlazor
    /// theme, so dark/light mode still applies automatically. See <see cref="KeyboardPalette"/>.
    /// </summary>
    [Parameter] public KeyboardPalette? Palette { get; set; }

    /// <summary>Raised when the Enter key is pressed.</summary>
    [Parameter] public EventCallback OnEnter { get; set; }

    /// <summary>Raised when an Escape (<c>{esc}</c>) key is pressed. Add an <c>{esc}</c> token to a custom layout to surface it.</summary>
    [Parameter] public EventCallback OnEscape { get; set; }

    /// <summary>
    /// Raised when a Cancel (<c>{cancel}</c>) key is pressed. Add a <c>{cancel}</c> token to a custom
    /// layout to surface it; the global docked keyboard uses this to revert and dismiss.
    /// </summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    /// <summary>
    /// Overrides the label shown on the Cancel (<c>{cancel}</c>) key. When unset it shows <c>"Cancel"</c>.
    /// </summary>
    [Parameter] public string? CancelLabel { get; set; }

    /// <summary>
    /// When <see langword="true"/>, the keyboard starts with caps lock on (letters upper-cased until the
    /// shift key turns it off). Default <see langword="false"/>. Applied once on first render; toggling the
    /// shift key afterwards behaves normally.
    /// </summary>
    [Parameter] public bool StartCapsLocked { get; set; }

    /// <summary>
    /// When set, the keyboard runs in <em>emit mode</em>: each press raises this callback instead of
    /// mutating <see cref="Value"/>, letting a host route the input elsewhere (for example into the
    /// caret of the currently focused field — see <see cref="MudKeyboardHost"/>). Shift, caps and the
    /// symbol/letter toggle are still managed internally; <see cref="MaxLength"/> is ignored in this
    /// mode (the host enforces any limit on its target).
    /// </summary>
    [Parameter] public EventCallback<KeyboardInput> OnInput { get; set; }

    // In emit mode the keyboard produces KeyboardInput events rather than editing its own Value.
    private bool EmitMode => OnInput.HasDelegate;

    // Apply the caps-lock default exactly once. Parameters are set before OnInitialized runs, so
    // StartCapsLocked is available here; doing it in OnParametersSet instead would re-lock caps on every
    // re-render and the user could never turn it off.
    protected override void OnInitialized()
    {
        if (StartCapsLocked)
        {
            _shiftState = ShiftState.Locked;
        }
    }

    protected override void OnParametersSet()
    {
        _baseLayout = Layout ?? (Variant == KeyboardVariant.Custom ? null : LayoutLibrary.ForVariant(Variant));
        // A custom Layout opts into the symbol face only by supplying its own SymbolLayout.
        _symbolLayout = SymbolLayout ?? (Layout is null ? LayoutLibrary.SymbolsForVariant(Variant) : null);

        // Nothing to flip to → never sit on the (missing) symbol face.
        if (_symbolLayout is null)
        {
            _symbolMode = false;
        }

        RebuildKeys();
    }

    // The face currently on screen: the symbol layout while flipped, otherwise the base layout.
    private KeyboardLayout? ActiveLayout =>
        _symbolMode && _symbolLayout is not null ? _symbolLayout : _baseLayout;

    private void RebuildKeys()
    {
        _displayKeys = ActiveLayout is { } layout
            ? KeyboardEngine.BuildDisplayKeys(layout, _shiftState, _symbolMode)
            : [];

        // A custom Cancel label overrides the default "Cancel" face on any {cancel} key in the layout.
        if (!string.IsNullOrWhiteSpace(CancelLabel) && CancelLabel != "Cancel")
        {
            _displayKeys = RelabelCancelKeys(_displayKeys, CancelLabel);
        }
    }

    // Returns the rows with every {cancel} key's display label swapped for the custom label. Touches only
    // the cancel keys (returning the original row otherwise), so non-cancel layouts allocate nothing.
    private static IReadOnlyList<IReadOnlyList<KeyboardKey>> RelabelCancelKeys(
        IReadOnlyList<IReadOnlyList<KeyboardKey>> rows, string label)
    {
        var result = new IReadOnlyList<KeyboardKey>[rows.Count];
        for (var r = 0; r < rows.Count; r++)
        {
            var row = rows[r];
            KeyboardKey[]? rebuilt = null;
            for (var c = 0; c < row.Count; c++)
            {
                if (row[c].ActionToken == KeyTokens.Cancel)
                {
                    rebuilt ??= [.. row];
                    rebuilt[c] = row[c] with { DisplayLabel = label };
                }
            }

            result[r] = rebuilt ?? row;
        }

        return result;
    }

    private async Task HandleKeyPressAsync(KeyboardKey key)
    {
        // Shift is special: a single click arms a one-shot; a double-click (handled separately) locks caps.
        if (key.ActionToken == KeyTokens.Shift)
        {
            HandleShiftClick();
            return;
        }

        // The {sym} key flips the whole surface between its letter and numbers/symbols faces.
        if (key.ActionToken == KeyTokens.SymbolToggle)
        {
            ToggleSymbolMode();
            return;
        }

        switch (key.ActionToken)
        {
            case KeyTokens.Enter:
                if (EmitMode)
                {
                    await OnInput.InvokeAsync(KeyboardInput.Enter);
                }

                await OnEnter.InvokeAsync();
                break;
            case KeyTokens.Escape:
                if (EmitMode)
                {
                    await OnInput.InvokeAsync(KeyboardInput.Escape);
                }

                await OnEscape.InvokeAsync();
                break;
            case KeyTokens.Cancel:
                if (EmitMode)
                {
                    await OnInput.InvokeAsync(KeyboardInput.Cancel);
                }

                await OnCancel.InvokeAsync();
                break;
            case KeyTokens.Backspace:
                if (EmitMode)
                {
                    await OnInput.InvokeAsync(KeyboardInput.Backspace);
                }
                else
                {
                    await SetValueAsync(KeyboardEngine.Backspace(Value));
                }

                break;
            case KeyTokens.Space:
                if (EmitMode)
                {
                    await OnInput.InvokeAsync(KeyboardInput.Char(" "));
                }
                else
                {
                    await SetValueAsync(KeyboardEngine.Append(Value, " ", MaxLength));
                }

                break;
            case KeyTokens.Sign:
                if (EmitMode)
                {
                    await OnInput.InvokeAsync(KeyboardInput.Sign);
                }
                else
                {
                    await SetValueAsync(KeyboardEngine.ToggleSign(Value));
                }

                break;
            default:
                // Never type an unhandled command token (e.g. a stray {caps} in a custom layout).
                if (KeyTokens.IsCommand(key.ActionToken))
                {
                    break;
                }

                var text = KeyboardEngine.ApplyCase(key.ActionToken, _shiftState != ShiftState.Off);
                if (EmitMode)
                {
                    await OnInput.InvokeAsync(KeyboardInput.Char(text));
                }
                else
                {
                    await SetValueAsync(KeyboardEngine.Append(Value, text, MaxLength));
                }

                break;
        }

        // A one-shot shift releases after any key press; caps lock stays on.
        if (_shiftState == ShiftState.OneShot)
        {
            _shiftState = ShiftState.Off;
            RebuildKeys();
        }
    }

    // Flips between the letter face and the numbers/symbols face. Shift is meaningless on the
    // symbol face, so it is cleared on every flip for predictable casing back on the letters.
    private void ToggleSymbolMode()
    {
        if (_symbolLayout is null)
        {
            return;
        }

        _symbolMode = !_symbolMode;
        _shiftState = ShiftState.Off;
        RebuildKeys();
    }

    // A single click arms a one-shot shift; clicking again while locked turns caps off.
    private void HandleShiftClick()
    {
        _shiftState = _shiftState == ShiftState.Locked ? ShiftState.Off : ShiftState.OneShot;
        RebuildKeys();
    }

    // A double-click on shift locks caps on (stays until shift is clicked again).
    private void HandleDoublePress(KeyboardKey key)
    {
        if (key.ActionToken == KeyTokens.Shift)
        {
            _shiftState = ShiftState.Locked;
            RebuildKeys();
        }
    }

    private async Task SetValueAsync(string newValue)
    {
        if (string.Equals(newValue, Value, StringComparison.Ordinal))
        {
            return;
        }

        Value = newValue;
        await ValueChanged.InvokeAsync(Value);
    }
}
