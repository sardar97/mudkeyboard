@namespace MudKeyboard.Components

<MudPaper Class="@Class" Style="@Style" Elevation="0">
    <KeyGrid Keys="@_displayKeys" Disabled="Disabled" DropShadow="@DropShadow" OnKeyPress="@HandleKeyPressAsync" OnKeyDoublePress="@HandleDoublePress" />
</MudPaper>

@code {
    private KeyboardLayout? _layout;
    private IReadOnlyList<IReadOnlyList<KeyboardKey>> _displayKeys = [];
    private ShiftState _shiftState = ShiftState.Off;

    /// <summary>The current value, two-way bindable via <c>@bind-Value</c>.</summary>
    [Parameter] public string Value { get; set; } = string.Empty;

    /// <summary>Raised when <see cref="Value"/> changes.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>An explicit layout. When set, it overrides <see cref="Variant"/>.</summary>
    [Parameter] public KeyboardLayout? Layout { get; set; }

    /// <summary>Which built-in surface to show when <see cref="Layout"/> is not set. Default <see cref="KeyboardVariant.Full"/>.</summary>
    [Parameter] public KeyboardVariant Variant { get; set; } = KeyboardVariant.Full;

    /// <summary>Optional maximum length of <see cref="Value"/>.</summary>
    [Parameter] public int? MaxLength { get; set; }

    /// <summary>Disables every key.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Whether the keys cast a drop shadow. Set <see langword="false"/> for flat keys. Default <see langword="true"/>.</summary>
    [Parameter] public bool DropShadow { get; set; } = true;

    /// <summary>Extra CSS classes for the root element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Extra inline styles for the root element.</summary>
    [Parameter] public string? Style { get; set; }

    /// <summary>Raised when the Enter key is pressed.</summary>
    [Parameter] public EventCallback OnEnter { get; set; }

    /// <summary>Raised when an Escape (<c>{esc}</c>) key is pressed. Add an <c>{esc}</c> token to a custom layout to surface it.</summary>
    [Parameter] public EventCallback OnEscape { get; set; }

    protected override void OnParametersSet()
    {
        _layout = Layout ?? (Variant == KeyboardVariant.Custom ? null : LayoutLibrary.ForVariant(Variant));
        RebuildKeys();
    }

    private void RebuildKeys() =>
        _displayKeys = _layout is null
            ? []
            : KeyboardEngine.BuildDisplayKeys(_layout, _shiftState);

    private async Task HandleKeyPressAsync(KeyboardKey key)
    {
        // Shift is special: a single click arms a one-shot; a double-click (handled separately) locks caps.
        if (key.ActionToken == KeyTokens.Shift)
        {
            HandleShiftClick();
            return;
        }

        switch (key.ActionToken)
        {
            case KeyTokens.Enter:
                await OnEnter.InvokeAsync();
                break;
            case KeyTokens.Escape:
                await OnEscape.InvokeAsync();
                break;
            case KeyTokens.Backspace:
                await SetValueAsync(KeyboardEngine.Backspace(Value));
                break;
            case KeyTokens.Space:
                await SetValueAsync(KeyboardEngine.Append(Value, " ", MaxLength));
                break;
            default:
                // Never type an unhandled command token (e.g. a stray {caps} in a custom layout).
                if (KeyTokens.IsCommand(key.ActionToken))
                {
                    break;
                }

                var text = KeyboardEngine.ApplyCase(key.ActionToken, _shiftState != ShiftState.Off);
                await SetValueAsync(KeyboardEngine.Append(Value, text, MaxLength));
                break;
        }

        // A one-shot shift releases after any key press; caps lock stays on.
        if (_shiftState == ShiftState.OneShot)
        {
            _shiftState = ShiftState.Off;
            RebuildKeys();
        }
    }

    // A single click arms a one-shot shift; clicking again while locked turns caps off.
    private void HandleShiftClick()
    {
        _shiftState = _shiftState == ShiftState.Locked ? ShiftState.Off : ShiftState.OneShot;
        RebuildKeys();
    }

    // A double-click on shift locks caps on (stays until shift is clicked again).
    private void HandleDoublePress(KeyboardKey key)
    {
        if (key.ActionToken == KeyTokens.Shift)
        {
            _shiftState = ShiftState.Locked;
            RebuildKeys();
        }
    }

    private async Task SetValueAsync(string newValue)
    {
        if (string.Equals(newValue, Value, StringComparison.Ordinal))
        {
            return;
        }

        Value = newValue;
        await ValueChanged.InvokeAsync(Value);
    }
}
