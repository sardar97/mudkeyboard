@namespace MudKeyboard.Components

<MudPaper Class="@Class" Style="@KeyboardPalette.Compose(Palette, Style)" Elevation="0"
          role="group" aria-label="@EffectiveAriaLabel">
    <KeyGrid Keys="_keys" Disabled="Disabled" Sound="@Sound" SoundSrc="@SoundSrc" OnKeyPress="@HandleKeyPressAsync" />
</MudPaper>

@code {
    private IReadOnlyList<IReadOnlyList<KeyboardKey>> _keys = [];

    /// <summary>The formatted currency value (for example <c>£1.23</c>), two-way bindable.</summary>
    [Parameter] public string Value { get; set; } = string.Empty;

    /// <summary>Raised when <see cref="Value"/> changes.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>Currency symbol prefix. Default <c>£</c>.</summary>
    [Parameter] public string CurrencySymbol { get; set; } = "£";

    /// <summary>
    /// When <see langword="true"/>, shows a <c>±</c> sign-toggle key so the amount can be made negative
    /// (formatted as <c>-£1.23</c>). Default <see langword="false"/>.
    /// </summary>
    [Parameter] public bool AllowNegative { get; set; }

    /// <summary>Number of fractional digits the value is formatted with. Default <c>2</c>.</summary>
    [Parameter] public int DecimalPlaces { get; set; } = 2;

    /// <summary>Optional cap on the number of entered digits.</summary>
    [Parameter] public int? MaxLength { get; set; }

    /// <summary>Disables every key.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>
    /// When <see langword="true"/>, a short click sound plays on every key press. Played via a
    /// Blazor-rendered <c>&lt;audio&gt;</c> element — no JavaScript. Default <see langword="false"/>.
    /// </summary>
    [Parameter] public bool Sound { get; set; }

    /// <summary>
    /// Optional source for the click sound (any URL or <c>data:</c> URI). When unset the built-in
    /// synthesised click is used. Ignored unless <see cref="Sound"/> is set.
    /// </summary>
    [Parameter] public string? SoundSrc { get; set; }

    /// <summary>Raised when the Enter key is pressed.</summary>
    [Parameter] public EventCallback OnEnter { get; set; }

    /// <summary>Extra CSS classes for the root element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Extra inline styles for the root element.</summary>
    [Parameter] public string? Style { get; set; }

    /// <summary>
    /// Accessible name for the pricepad, applied to the root <c>role="group"</c> as its
    /// <c>aria-label</c>. Default <c>"Price entry keypad"</c>.
    /// </summary>
    [Parameter] public string? AriaLabel { get; set; }

    private string EffectiveAriaLabel => string.IsNullOrWhiteSpace(AriaLabel) ? "Price entry keypad" : AriaLabel;

    /// <summary>
    /// Optional colour overrides for this pricepad. Unset slots inherit the ambient MudBlazor
    /// theme, so dark/light mode still applies automatically. See <see cref="KeyboardPalette"/>.
    /// </summary>
    [Parameter] public KeyboardPalette? Palette { get; set; }

    protected override void OnParametersSet() =>
        _keys = KeyboardKey.FromRows((AllowNegative ? LayoutLibrary.PriceSigned : LayoutLibrary.Price).Rows);

    private async Task HandleKeyPressAsync(KeyboardKey key)
    {
        // The sign is carried in the formatted Value (a leading "-"); preserve it across digit edits.
        var negative = PricepadFormatter.IsNegative(Value);
        switch (key.ActionToken)
        {
            case KeyTokens.Enter:
                await OnEnter.InvokeAsync();
                break;
            case KeyTokens.Sign:
                await SetFormattedAsync(PricepadFormatter.ExtractDigits(Value), !negative);
                break;
            case KeyTokens.Backspace:
            {
                var digits = PricepadFormatter.ExtractDigits(Value);
                if (digits.Length > 0)
                {
                    digits = digits[..^1];
                }

                await SetFormattedAsync(digits, negative);
                break;
            }
            default:
            {
                // Price layout only emits digit tokens ("7", "00", …); append then re-format.
                var digits = PricepadFormatter.ExtractDigits(Value) + key.ActionToken;
                if (MaxLength is { } max && digits.Length > max)
                {
                    break;
                }

                await SetFormattedAsync(digits, negative);
                break;
            }
        }
    }

    private async Task SetFormattedAsync(string digits, bool negative)
    {
        var formatted = PricepadFormatter.Format(digits, CurrencySymbol, DecimalPlaces, negative);
        if (string.Equals(formatted, Value, StringComparison.Ordinal))
        {
            return;
        }

        Value = formatted;
        await ValueChanged.InvokeAsync(Value);
    }
}
