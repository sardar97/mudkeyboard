@page "/components/docked-keyboard"
@implements IDisposable
@inject DocsKeyboardToolbarState Toolbar

<PageTitle>Docked keyboard · Components</PageTitle>

<PageHeader Overline="Components"
            Title="Global docked keyboard"
            Lead="One host component shows a keyboard that slides up from the bottom of the screen whenever a field is focused, and types at that field's caret. This is the single MudKeyboard feature that uses JavaScript." />

<MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mb-6 docs-alert-filled">
    <strong>Try it now.</strong> Tap any field in the live demo below — the docked keyboard slides up
    from the bottom of <em>this</em> page. The layout is chosen per field (text → QWERTY,
    number → numpad, money → pence-first). For fields bound to a numeric type, use
    <code>MudKeyboardNumericField&lt;T&gt;</code> and the keypad follows the type — see
    <MudLink Href="components/docked-keyboard#numeric">Type-aware numeric fields</MudLink> below.
</MudAlert>

<ExampleCard Title="Focus any field"
             Description="These three fields are opted in with data-mudkeyboard. Tap one to raise the docked keyboard."
             Code="@DemoCode">
    <MudTextField @bind-Value="_text" Label="Text (QWERTY)" Variant="Variant.Outlined" Immediate="true"
                  UserAttributes="@(new() { ["data-mudkeyboard"] = "true" })" />
    <MudTextField @bind-Value="_number" Label="Number (numpad)" Variant="Variant.Outlined" Immediate="true" InputMode="InputMode.numeric"
                  UserAttributes="@(new() { ["data-mudkeyboard"] = "true" })" />
    <MudTextField @bind-Value="_money" Label="Money (pence-first → type 5·2·3 → 5.23)" Variant="Variant.Outlined" Immediate="true"
                  UserAttributes="@(new() { ["data-mudkeyboard"] = "true", ["data-mudkeyboard-layout"] = "money" })" />
</ExampleCard>

<MudText id="setup" Typo="Typo.h5" Class="docs-section-title">Setup</MudText>
<div class="docs-prose">
    <p><strong>1. Register the services</strong> in <code class="docs-inline-code">Program.cs</code>:</p>
</div>
<CodeBlock Language="csharp" Code="@RegisterCode" />
<div class="docs-prose mt-3">
    <p><strong>2. Place the host once</strong> in your main layout, next to the MudBlazor providers:</p>
</div>
<CodeBlock Language="razor" Code="@HostCode" />
<div class="docs-prose mt-3">
    <p>
        That's it. With the default attach mode, every editable text/number field now raises the keyboard
        on focus and the layout is inferred from the field. Add
        <code class="docs-inline-code">Immediate="true"</code> to MudBlazor inputs so the bound value
        updates as keys are tapped.
    </p>
</div>

<MudText id="attach" Typo="Typo.h5" Class="docs-section-title">Choosing which fields attach</MudText>
<div class="docs-prose">
    <p>
        <code class="docs-inline-code">KeyboardAttachMode</code> controls the policy. In
        <code class="docs-inline-code">AllInputs</code> (the default) every editable field attaches unless
        opted out; in <code class="docs-inline-code">OptIn</code> only fields explicitly marked attach.
    </p>
</div>
<CodeBlock Language="csharp" Code="@OptInCode" />
<ParamTable Members="DataAttributes" NameHeader="Attribute" ShowDefault="false" />
<CodeBlock Language="razor" Code="@AttrCode" />

<MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="my-4" Dense="true">
    This documentation site itself registers the host in <code class="docs-inline-code">OptIn</code> mode, so
    only the fields above (marked with <code class="docs-inline-code">data-mudkeyboard</code>) raise the
    docked keyboard — the inline-keyboard examples elsewhere on the site are left untouched.
</MudAlert>

<MudText id="numeric" Typo="Typo.h5" Class="docs-section-title">Type-aware numeric fields</MudText>
<div class="docs-prose">
    <p>
        The focus-capture shim only sees the rendered HTML, and a <code class="docs-inline-code">decimal</code>,
        a <code class="docs-inline-code">double</code> and a <code class="docs-inline-code">float</code> all
        render the same <code class="docs-inline-code">inputmode="decimal"</code> — so JavaScript alone can't
        tell a currency field from a plain decimal. <code class="docs-inline-code">MudKeyboardNumericField&lt;T&gt;</code>
        wraps <code class="docs-inline-code">MudNumericField&lt;T&gt;</code> and resolves the keypad from the
        bound CLR type, with no data attribute to remember:
    </p>
    <ul>
        <li><code class="docs-inline-code">decimal</code> → the <strong>money</strong> keypad (pence-first, like <MudLink Href="components/pricepad">MudPricepad</MudLink>).</li>
        <li><code class="docs-inline-code">double</code> / <code class="docs-inline-code">float</code> → the numeric keypad <strong>with</strong> a "." key.</li>
        <li><code class="docs-inline-code">int</code>, <code class="docs-inline-code">long</code>, <code class="docs-inline-code">short</code>, … → the numeric keypad <strong>without</strong> a "." key.</li>
    </ul>
    <p>
        It forwards the common <code class="docs-inline-code">MudNumericField</code> parameters
        (<code class="docs-inline-code">For</code>, <code class="docs-inline-code">Format</code>,
        <code class="docs-inline-code">Min</code>/<code class="docs-inline-code">Max</code>/<code class="docs-inline-code">Step</code>,
        <code class="docs-inline-code">Adornment</code>, …) and any extra attributes. Set
        <code class="docs-inline-code">DockedKeyboardLayout</code> to override the auto choice for a field.
    </p>
</div>
<ExampleCard Title="Keypad follows the bound type"
             Description="Bound to decimal, double and int respectively. The site runs in OptIn mode, so each field is opted in with DockedKeyboard."
             Code="@NumericCode">
    <MudKeyboardNumericField @bind-Value="_price" T="decimal" Format="N2" Label="Price (decimal → money £)"
                             Variant="Variant.Outlined" Immediate="true" Min="0m" DockedKeyboard="true"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyPound" />
    <MudKeyboardNumericField @bind-Value="_measure" T="double" Label="Measurement (double → numeric with .)"
                             Variant="Variant.Outlined" Immediate="true" DockedKeyboard="true" />
    <MudKeyboardNumericField @bind-Value="_quantity" T="int" Label="Quantity (int → numeric, no .)"
                             Variant="Variant.Outlined" Immediate="true" DockedKeyboard="true" />
</ExampleCard>
<MudText id="numeric-parameters" Typo="Typo.subtitle1" Class="mt-4 mb-1"><b>MudKeyboardNumericField parameters</b></MudText>
<ParamTable Members="NumericFieldParameters" />
<div class="docs-prose mt-2">
    <p>
        A raw <code class="docs-inline-code">MudNumericField</code> still auto-detects integer
        (<code class="docs-inline-code">inputmode="numeric"</code> → plain numpad) vs. floating-point
        (<code class="docs-inline-code">inputmode="decimal"</code> → decimal keypad) on its own. Only the
        <code class="docs-inline-code">decimal</code> → money choice needs the bound type — which is exactly
        what the wrapper supplies. You can always force <code class="docs-inline-code">money</code> on a raw
        field with <code class="docs-inline-code">data-mudkeyboard-layout="money"</code>.
    </p>
</div>

<MudText id="negative" Typo="Typo.h5" Class="docs-section-title">Negative numbers (the ± key)</MudText>
<div class="docs-prose">
    <p>
        The numeric keypads (number, decimal and money) are positive-only by default. Set
        <code class="docs-inline-code">AllowNegative="true"</code> to add a <code class="docs-inline-code">±</code>
        sign-toggle key so a value can be made negative. On <code class="docs-inline-code">MudKeyboardNumericField</code>
        it is per field (it emits <code class="docs-inline-code">data-mudkeyboard-allow-negative</code>); on a
        raw field set that attribute yourself; or set <code class="docs-inline-code">AllowNegative</code> on the
        <code class="docs-inline-code">MudKeyboardHost</code> as a global default for every numeric keypad. The
        same option exists on the inline <MudLink Href="components/numpad">MudNumpad</MudLink> and
        <MudLink Href="components/pricepad">MudPricepad</MudLink>.
    </p>
</div>
<ExampleCard Title="± on the docked keypads"
             Description="Focus a field and tap ± to flip the sign. Works for plain numbers, decimals and pence-first money."
             Code="@NegativeCode">
    <MudKeyboardNumericField @bind-Value="_negInt" T="int" AllowNegative="true" DockedKeyboard="true"
                             Label="Temperature (int → numpad with ±)" Variant="Variant.Outlined" />
    <MudKeyboardNumericField @bind-Value="_negPrice" T="decimal" Format="N2" AllowNegative="true" DockedKeyboard="true"
                             Label="Adjustment (decimal → money with ±)" Variant="Variant.Outlined"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyPound" />
    <MudText Typo="Typo.body2" Class="mt-2">Bound: <b>@_negInt</b> · <b>@_negPrice.ToString("N2")</b></MudText>
</ExampleCard>

<MudText id="behaviour" Typo="Typo.h5" Class="docs-section-title">Built-in behaviour</MudText>
<div class="docs-prose">
    <ul>
        <li>The docked panel includes <strong>clear, copy, paste</strong> and <strong>cursor</strong> controls (cursor arrows are hidden for pence-first money entry, which always appends).</li>
        <li>It automatically docks <strong>one layer above the top-most element on the page</strong>, so it floats over dialogs and overlays. <code class="docs-inline-code">MinZIndex</code> sets the floor.</li>
        <li>Pressing <strong>⏎</strong> commits the value and closes the keyboard; the <strong>Cancel</strong> key (next to Enter, shown by default) reverts and closes. The chevron-down ⌄ Hide button appears only when the Cancel key is turned off.</li>
        <li>On the <strong>number and money keypads</strong>, the first digit pressed replaces the field's existing value (so a pre-filled <code class="docs-inline-code">6.00</code> becomes the typed amount, not <code class="docs-inline-code">6.005</code>); backspace, sign or a caret move resumes editing the existing value.</li>
        <li>The money layout reuses the same pence-first logic as <MudLink Href="components/pricepad">MudPricepad</MudLink>.</li>
        <li>It works on <strong>static-SSR pages</strong> too (it types via JavaScript, not Blazor binding) — see the <MudLink Href="features/ssr">Static SSR guide</MudLink>.</li>
        <li>While hidden it is <code class="docs-inline-code">inert</code> and <code class="docs-inline-code">aria-hidden</code> (out of the tab order); the toolbar and keys are fully labelled. See <MudLink Href="features/accessibility">Accessibility</MudLink>.</li>
    </ul>
</div>

<MudText id="validation" Typo="Typo.h5" Class="docs-section-title">Validation &amp; commit on close</MudText>
<div class="docs-prose">
    <p>
        The docked keyboard edits the field through the browser's native value setter, then mirrors a
        hardware keyboard's <code class="docs-inline-code">change</code> → <code class="docs-inline-code">blur</code>
        order: it commits the field the instant you press outside it — <strong>before</strong> the field
        blurs — and when <strong>⏎</strong> (or the <strong>Cancel</strong> key) closes the panel. So the value
        flows into your binding and the field's own validation runs on close, exactly as if you'd typed on a
        physical keyboard and clicked away. The field below is bound to an <code class="docs-inline-code">int</code>
        with <code class="docs-inline-code">Min="-10"</code>/<code class="docs-inline-code">Max="10"</code> and
        is <em>not</em> <code class="docs-inline-code">Immediate</code> — type something out of range (say
        <code class="docs-inline-code">100</code>) and tap away: it commits and clamps to
        <code class="docs-inline-code">10</code>.
    </p>
</div>
<ExampleCard Title="Commit + clamp when the keyboard closes"
             Description="Non-immediate field with Min/Max. Type an out-of-range value, then tap elsewhere — the value commits and is clamped, just like a hardware-keyboard blur."
             Code="@ValidationCode">
    <MudKeyboardNumericField @bind-Value="_rating" T="int" Min="-10" Max="10"
                             Label="Rating (Min -10 / Max 10, non-immediate)"
                             Variant="Variant.Outlined" DockedKeyboard="true" />
    <MudText Typo="Typo.body2" Class="mt-2">Bound value: <b>@_rating</b></MudText>
</ExampleCard>

<MudText id="toolbar" Typo="Typo.h5" Class="docs-section-title">Toolbar buttons (show, hide &amp; disable)</MudText>
<div class="docs-prose">
    <p>
        The panel's action buttons — <strong>Clear</strong>, <strong>Copy</strong>, <strong>Paste</strong>,
        the <strong>cursor arrows</strong> and <strong>Hide</strong> — are controlled by two
        <code class="docs-inline-code">MudKeyboardHost</code> parameters:
        <code class="docs-inline-code">VisibleActions</code> (which render) and
        <code class="docs-inline-code">DisabledActions</code> (which render greyed-out). Both take the
        <code class="docs-inline-code">[Flags]</code> enum <code class="docs-inline-code">KeyboardAction</code>,
        so you can hide or disable any button — globally or one at a time. Toggle the switches below, then
        focus a field above to see this page's own docked keyboard update live; the code shows the exact
        parameters for your selection.
    </p>
</div>
<MudPaper Class="pa-4 mb-3" Outlined="true">
    <div class="d-flex justify-space-between align-center mb-2 flex-wrap" style="gap:.5rem">
        <MudText Typo="Typo.subtitle2">Toolbar buttons</MudText>
        <MudButton Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Restore"
                   OnClick="@(() => Toolbar.Reset())">Reset</MudButton>
    </div>
    <MudSimpleTable Dense="true" Hover="false" Bordered="false" Elevation="0" Style="background:transparent">
        <thead>
            <tr><th>Button</th><th style="width:8rem">Visible</th><th style="width:8rem">Disabled</th></tr>
        </thead>
        <tbody>
            @foreach (var (action, label) in ToolbarButtons)
            {
                <tr>
                    <td>@label</td>
                    <td>
                        <MudSwitch T="bool" Color="Color.Primary" Value="@Toolbar.IsVisible(action)"
                                   ValueChanged="@(v => Toolbar.SetVisible(action, v))"
                                   aria-label="@($"Show {label} button")" />
                    </td>
                    <td>
                        <MudSwitch T="bool" Color="Color.Secondary" Value="@Toolbar.IsDisabled(action)"
                                   ValueChanged="@(v => Toolbar.SetDisabled(action, v))"
                                   Disabled="@(!Toolbar.IsVisible(action))"
                                   aria-label="@($"Disable {label} button")" />
                    </td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
    <MudText Typo="Typo.caption" Class="mt-1">Hiding wins over disabling — a hidden button isn't rendered at all. The cursor arrows never appear on the money keypad regardless.</MudText>
</MudPaper>
<CodeBlock Language="razor" Code="@ToolbarCode" />

<MudText id="edit-cancel" Typo="Typo.h5" Class="docs-section-title">Value preview, cancel &amp; backdrop</MudText>
<div class="docs-prose">
    <p>
        <code class="docs-inline-code">ShowValuePreview</code> (on by default) shows a bar at the top of the
        docked keyboard with the focused field's <strong>live value</strong> and a <strong>blinking caret</strong>
        at the cursor position — so the user always sees what they are editing and where the caret sits, even
        when the field is behind the panel. Focus a field that already contains text (say <em>"sardar"</em>)
        and it appears immediately; the keys edit it live, and the cursor moves with the ◂ ▸ arrows.
    </p>
    <p>
        <code class="docs-inline-code">ShowCancel</code> (on by default) renders a <strong>Cancel</strong> key
        next to <strong>Enter</strong>: Enter commits and closes, Cancel reverts to the value the field held at
        focus-in and closes. Rename the key with <code class="docs-inline-code">CancelLabel</code>, or set
        <code class="docs-inline-code">ShowCancel="false"</code> to drop it (which brings back the chevron-down
        Hide button). <code class="docs-inline-code">DefaultCapsLock="true"</code> makes the keyboard start
        with caps lock on; set it globally with <code class="docs-inline-code">AddMudKeyboard(o =&gt; o.DefaultCapsLock = true)</code>.
    </p>
    <p>
        <code class="docs-inline-code">ShowBackdrop="true"</code> dims the page behind the keyboard; a tap on
        the backdrop <strong>cancels</strong> the edit (reverts and closes). Set
        <code class="docs-inline-code">DisableBackdropClick="true"</code> so the backdrop no longer dismisses,
        requiring an explicit Enter or Cancel.
    </p>
</div>
<MudPaper Class="pa-4 mb-3" Outlined="true">
    <div class="d-flex justify-space-between align-center mb-2 flex-wrap" style="gap:.5rem">
        <MudText Typo="Typo.subtitle2">Live options — then focus a field at the top of this page</MudText>
        <MudButton Size="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Restore"
                   OnClick="@(() => Toolbar.Reset())">Reset</MudButton>
    </div>
    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="4">
        <MudSwitch T="bool" Color="Color.Primary" Value="@Toolbar.ShowValuePreview"
                   ValueChanged="@(v => Toolbar.ShowValuePreview = v)" Label="Value preview (with caret)" />
        <MudSwitch T="bool" Color="Color.Primary" Value="@Toolbar.ShowCancel"
                   ValueChanged="@(v => Toolbar.ShowCancel = v)" Label="Cancel key" />
        <MudSwitch T="bool" Color="Color.Primary" Value="@Toolbar.DefaultCapsLock"
                   ValueChanged="@(v => Toolbar.DefaultCapsLock = v)" Label="Caps lock by default" />
        <MudSwitch T="bool" Color="Color.Primary" Value="@Toolbar.ShowBackdrop"
                   ValueChanged="@(v => Toolbar.ShowBackdrop = v)" Label="Backdrop" />
        <MudSwitch T="bool" Color="Color.Secondary" Value="@Toolbar.DisableBackdropClick"
                   ValueChanged="@(v => Toolbar.DisableBackdropClick = v)" Label="Disable backdrop click" />
        <MudSwitch T="bool" Color="Color.Primary" Value="@Toolbar.Sound"
                   ValueChanged="@(v => Toolbar.Sound = v)" Label="Key click sound" />
    </MudStack>
</MudPaper>
<CodeBlock Language="razor" Code="@PreviewCode" />

<MudText id="sound" Typo="Typo.h5" Class="docs-section-title">Key click sound</MudText>
<div class="docs-prose">
    <p>
        <code class="docs-inline-code">Sound="true"</code> plays a short click on every key press. It is a
        Blazor-rendered <code class="docs-inline-code">&lt;audio&gt;</code> element — <strong>no JavaScript</strong> —
        so the same parameter works on the docked keyboard and the inline
        <MudLink Href="components/keyboard">MudKeyboard</MudLink>,
        <MudLink Href="components/numpad">MudNumpad</MudLink> and
        <MudLink Href="components/pricepad">MudPricepad</MudLink>. Point
        <code class="docs-inline-code">SoundSrc</code> at your own audio file (any URL or
        <code class="docs-inline-code">data:</code> URI) to replace the built-in click. Toggle it with the
        switch above, then tap a key. (Browsers only allow sound after the first user interaction, so the
        very first tap on a fresh page may be silent.)
    </p>
</div>
<CodeBlock Language="razor" Code="@SoundCode" />

<MudText id="parameters" Typo="Typo.h5" Class="docs-section-title">MudKeyboardHost parameters</MudText>
<ParamTable Members="HostParameters" />

<MudText id="js" Typo="Typo.h5" Class="docs-section-title">About the JavaScript</MudText>
<div class="docs-prose">
    <p>
        A browser can't report focus on arbitrary inputs to Blazor without JavaScript, so the docked
        keyboard uses one small ES module (<code class="docs-inline-code">mudKeyboard.js</code>, shipped as a
        static web asset). It does global focus capture and caret-aware insertion. All interop is confined
        to <code class="docs-inline-code">KeyboardInteropService</code>, and only primitive strings cross the
        boundary — so it stays AOT/trim-safe. The keyboard <em>core</em> remains 100% JavaScript-free.
    </p>
</div>

<div class="docs-nav-footer">
    <MudButton Href="components/pricepad" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">MudPricepad</MudButton>
    <MudButton Href="features/layouts" Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward">Layouts &amp; key tokens</MudButton>
</div>

@code {
    private string _text = string.Empty;
    private string _number = string.Empty;
    private string _money = string.Empty;
    private decimal _price;
    private double _measure;
    private int _quantity;
    private int _rating;

    // Restore the toolbar to defaults (all buttons visible) when leaving the page, so the live demo's
    // changes don't leak onto the rest of the site (the host is global, in MainLayout).
    public void Dispose() => Toolbar.Reset();

    // The toggleable toolbar buttons, in render order. CursorControl is the left+right arrow pair.
    private static readonly (KeyboardAction Action, string Label)[] ToolbarButtons =
    [
        (KeyboardAction.Clear, "Clear"),
        (KeyboardAction.Copy, "Copy"),
        (KeyboardAction.Paste, "Paste"),
        (KeyboardAction.CursorControl, "Cursor arrows"),
        (KeyboardAction.Hide, "Hide"),
    ];

    // Live <MudKeyboardHost …/> markup for the current toolbar selection.
    private string ToolbarCode
    {
        get
        {
            var sb = new System.Text.StringBuilder("<MudKeyboardHost");
            if (Toolbar.VisibleActions != KeyboardAction.All)
            {
                sb.Append("\n                 VisibleActions=\"").Append(FormatActions(Toolbar.VisibleActions)).Append('"');
            }
            if (Toolbar.DisabledActions != KeyboardAction.None)
            {
                sb.Append("\n                 DisabledActions=\"").Append(FormatActions(Toolbar.DisabledActions)).Append('"');
            }
            return sb.Append(" />").ToString();
        }
    }

    private static string FormatActions(KeyboardAction actions)
    {
        if (actions == KeyboardAction.None)
        {
            return "KeyboardAction.None";
        }

        if (actions == KeyboardAction.All)
        {
            return "KeyboardAction.All";
        }

        var parts = ToolbarButtons
            .Where(b => (actions & b.Action) == b.Action)
            .Select(b => "KeyboardAction." + b.Action);
        return string.Join(" | ", parts);
    }

    private int _negInt;
    private decimal _negPrice;

    private const string NegativeCode = """
@* AllowNegative adds the ± sign-toggle key. Per field on the wrapper, or globally on MudKeyboardHost. *@
<MudKeyboardNumericField @bind-Value="_negInt" T="int" AllowNegative="true" DockedKeyboard="true" />

<MudKeyboardNumericField @bind-Value="_negPrice" T="decimal" Format="N2" AllowNegative="true"
                         Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyPound"
                         DockedKeyboard="true" />

@* …or enable ± for every numeric docked field at once: *@
<MudKeyboardHost AllowNegative="true" />
""";

    private const string PreviewCode = """
@* Value preview (with caret) and the Cancel key are on by default. Defaults shown explicitly here; you
   can drop any line. Add a dimming backdrop and require an explicit Enter / Cancel to dismiss. *@
<MudKeyboardHost ShowValuePreview="true"
                 ShowCancel="true"
                 CancelLabel="Cancel"
                 ShowBackdrop="true"
                 DisableBackdropClick="true" />

@* Start with caps lock on — per host, or globally in Program.cs: *@
<MudKeyboardHost DefaultCapsLock="true" />
@* builder.Services.AddMudKeyboard(o => o.DefaultCapsLock = true); *@
""";

    private const string SoundCode = """
@* A click on every key press — pure Blazor <audio>, no JavaScript. The same Sound / SoundSrc
   parameters exist on the inline MudKeyboard / MudNumpad / MudPricepad too. *@
<MudKeyboardHost Sound="true" />

@* Inline, with your own sound file: *@
<MudNumpad @bind-Value="_qty" Sound="true" SoundSrc="/sounds/tap.mp3" />
""";

    private const string ValidationCode = """
@* Non-immediate (the default) + Min/Max. The docked keyboard commits and validates on close, so an
   out-of-range value is clamped when you tap away — exactly like a hardware-keyboard blur. *@
<MudKeyboardNumericField @bind-Value="_rating" T="int" Min="-10" Max="10"
                         Label="Rating" DockedKeyboard="true" />
<MudText>Bound value: <b>@_rating</b></MudText>
""";

    private const string NumericCode = """
@* The keypad is chosen from T — no data attribute needed. (DockedKeyboard="true" because
   this site runs in OptIn mode; in the default AllInputs mode you can omit it.) *@
<MudKeyboardNumericField @bind-Value="Model.Price" T="decimal" Format="N2"
                         Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyPound"
                         DockedKeyboard="true" />   @* decimal → money keypad *@

<MudKeyboardNumericField @bind-Value="_measure" T="double" DockedKeyboard="true" /> @* double → numeric with . *@

<MudKeyboardNumericField @bind-Value="_quantity" T="int" DockedKeyboard="true" />   @* int → numeric, no . *@
""";

    private const string DemoCode = """
@* The site runs the host in OptIn mode, so fields are marked with data-mudkeyboard. *@
<MudTextField @bind-Value="_text" Label="Text (QWERTY)" Immediate="true"
              UserAttributes="@(new() { ["data-mudkeyboard"] = "true" })" />

<MudTextField @bind-Value="_number" Label="Number (numpad)" Immediate="true" InputMode="InputMode.numeric"
              UserAttributes="@(new() { ["data-mudkeyboard"] = "true" })" />

<MudTextField @bind-Value="_money" Label="Money" Immediate="true"
              UserAttributes="@(new() {
                  ["data-mudkeyboard"] = "true",
                  ["data-mudkeyboard-layout"] = "money" })" />
""";

    private const string RegisterCode = """
using MudKeyboard.Extensions;

builder.Services.AddMudServices();   // MudBlazor
builder.Services.AddMudKeyboard();   // MudKeyboard docked-keyboard services
""";

    private const string HostCode = """
<MudThemeProvider @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudKeyboardHost />   @* once, anywhere in the layout *@
""";

    private const string OptInCode = """
using MudKeyboard.Services;

// Default — attach to every editable field (opt out per-field with data-mudkeyboard-ignore)
builder.Services.AddMudKeyboard();

// Or: only attach to fields explicitly marked with data-mudkeyboard
builder.Services.AddMudKeyboard(o => o.AttachMode = KeyboardAttachMode.OptIn);
""";

