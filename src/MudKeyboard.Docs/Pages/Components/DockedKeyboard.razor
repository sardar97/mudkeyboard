@page "/components/docked-keyboard"

<PageTitle>Docked keyboard · Components</PageTitle>

<PageHeader Overline="Components"
            Title="Global docked keyboard"
            Lead="One host component shows a keyboard that slides up from the bottom of the screen whenever a field is focused, and types at that field's caret. This is the single MudKeyboard feature that uses JavaScript." />

<MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="mb-6">
    <strong>Try it now.</strong> Tap any field in the live demo below — the docked keyboard slides up
    from the bottom of <em>this</em> page. The layout is chosen per field (text → QWERTY,
    number → numpad, money → pence-first). For fields bound to a numeric type, use
    <code>MudKeyboardNumericField&lt;T&gt;</code> and the keypad follows the type — see
    <MudLink Href="components/docked-keyboard#numeric">Type-aware numeric fields</MudLink> below.
</MudAlert>

<ExampleCard Title="Focus any field"
             Description="These three fields are opted in with data-mudkeyboard. Tap one to raise the docked keyboard."
             Code="@DemoCode">
    <MudTextField @bind-Value="_text" Label="Text (QWERTY)" Variant="Variant.Outlined" Immediate="true"
                  UserAttributes="@(new() { ["data-mudkeyboard"] = "true" })" />
    <MudTextField @bind-Value="_number" Label="Number (numpad)" Variant="Variant.Outlined" Immediate="true" InputMode="InputMode.numeric"
                  UserAttributes="@(new() { ["data-mudkeyboard"] = "true" })" />
    <MudTextField @bind-Value="_money" Label="Money (pence-first → type 5·2·3 → 5.23)" Variant="Variant.Outlined" Immediate="true"
                  UserAttributes="@(new() { ["data-mudkeyboard"] = "true", ["data-mudkeyboard-layout"] = "money" })" />
</ExampleCard>

<MudText id="setup" Typo="Typo.h5" Class="docs-section-title">Setup</MudText>
<div class="docs-prose">
    <p><strong>1. Register the services</strong> in <code class="docs-inline-code">Program.cs</code>:</p>
</div>
<CodeBlock Language="csharp" Code="@RegisterCode" />
<div class="docs-prose mt-3">
    <p><strong>2. Place the host once</strong> in your main layout, next to the MudBlazor providers:</p>
</div>
<CodeBlock Language="razor" Code="@HostCode" />
<div class="docs-prose mt-3">
    <p>
        That's it. With the default attach mode, every editable text/number field now raises the keyboard
        on focus and the layout is inferred from the field. Add
        <code class="docs-inline-code">Immediate="true"</code> to MudBlazor inputs so the bound value
        updates as keys are tapped.
    </p>
</div>

<MudText id="attach" Typo="Typo.h5" Class="docs-section-title">Choosing which fields attach</MudText>
<div class="docs-prose">
    <p>
        <code class="docs-inline-code">KeyboardAttachMode</code> controls the policy. In
        <code class="docs-inline-code">AllInputs</code> (the default) every editable field attaches unless
        opted out; in <code class="docs-inline-code">OptIn</code> only fields explicitly marked attach.
    </p>
</div>
<CodeBlock Language="csharp" Code="@OptInCode" />
<ParamTable Members="DataAttributes" NameHeader="Attribute" ShowDefault="false" />
<CodeBlock Language="razor" Code="@AttrCode" />

<MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="my-4" Dense="true">
    This documentation site itself registers the host in <code class="docs-inline-code">OptIn</code> mode, so
    only the fields above (marked with <code class="docs-inline-code">data-mudkeyboard</code>) raise the
    docked keyboard — the inline-keyboard examples elsewhere on the site are left untouched.
</MudAlert>

<MudText id="numeric" Typo="Typo.h5" Class="docs-section-title">Type-aware numeric fields</MudText>
<div class="docs-prose">
    <p>
        The focus-capture shim only sees the rendered HTML, and a <code class="docs-inline-code">decimal</code>,
        a <code class="docs-inline-code">double</code> and a <code class="docs-inline-code">float</code> all
        render the same <code class="docs-inline-code">inputmode="decimal"</code> — so JavaScript alone can't
        tell a currency field from a plain decimal. <code class="docs-inline-code">MudKeyboardNumericField&lt;T&gt;</code>
        wraps <code class="docs-inline-code">MudNumericField&lt;T&gt;</code> and resolves the keypad from the
        bound CLR type, with no data attribute to remember:
    </p>
    <ul>
        <li><code class="docs-inline-code">decimal</code> → the <strong>money</strong> keypad (pence-first, like <MudLink Href="components/pricepad">MudPricepad</MudLink>).</li>
        <li><code class="docs-inline-code">double</code> / <code class="docs-inline-code">float</code> → the numeric keypad <strong>with</strong> a "." key.</li>
        <li><code class="docs-inline-code">int</code>, <code class="docs-inline-code">long</code>, <code class="docs-inline-code">short</code>, … → the numeric keypad <strong>without</strong> a "." key.</li>
    </ul>
    <p>
        It forwards the common <code class="docs-inline-code">MudNumericField</code> parameters
        (<code class="docs-inline-code">For</code>, <code class="docs-inline-code">Format</code>,
        <code class="docs-inline-code">Min</code>/<code class="docs-inline-code">Max</code>/<code class="docs-inline-code">Step</code>,
        <code class="docs-inline-code">Adornment</code>, …) and any extra attributes. Set
        <code class="docs-inline-code">DockedKeyboardLayout</code> to override the auto choice for a field.
    </p>
</div>
<ExampleCard Title="Keypad follows the bound type"
             Description="Bound to decimal, double and int respectively. The site runs in OptIn mode, so each field is opted in with DockedKeyboard."
             Code="@NumericCode">
    <MudKeyboardNumericField @bind-Value="_price" T="decimal" Format="N2" Label="Price (decimal → money £)"
                             Variant="Variant.Outlined" Immediate="true" Min="0m" DockedKeyboard="true"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyPound" />
    <MudKeyboardNumericField @bind-Value="_measure" T="double" Label="Measurement (double → numeric with .)"
                             Variant="Variant.Outlined" Immediate="true" DockedKeyboard="true" />
    <MudKeyboardNumericField @bind-Value="_quantity" T="int" Label="Quantity (int → numeric, no .)"
                             Variant="Variant.Outlined" Immediate="true" DockedKeyboard="true" />
</ExampleCard>
<MudText id="numeric-parameters" Typo="Typo.subtitle1" Class="mt-4 mb-1"><b>MudKeyboardNumericField parameters</b></MudText>
<ParamTable Members="NumericFieldParameters" />
<div class="docs-prose mt-2">
    <p>
        A raw <code class="docs-inline-code">MudNumericField</code> still auto-detects integer
        (<code class="docs-inline-code">inputmode="numeric"</code> → plain numpad) vs. floating-point
        (<code class="docs-inline-code">inputmode="decimal"</code> → decimal keypad) on its own. Only the
        <code class="docs-inline-code">decimal</code> → money choice needs the bound type — which is exactly
        what the wrapper supplies. You can always force <code class="docs-inline-code">money</code> on a raw
        field with <code class="docs-inline-code">data-mudkeyboard-layout="money"</code>.
    </p>
</div>

<MudText id="behaviour" Typo="Typo.h5" Class="docs-section-title">Built-in behaviour</MudText>
<div class="docs-prose">
    <ul>
        <li>The docked panel includes <strong>clear, copy, paste</strong> and <strong>cursor</strong> controls (cursor arrows are hidden for pence-first money entry, which always appends).</li>
        <li>It automatically docks <strong>one layer above the top-most element on the page</strong>, so it floats over dialogs and overlays. <code class="docs-inline-code">MinZIndex</code> sets the floor.</li>
        <li>Pressing <strong>⏎</strong> commits the value and closes the keyboard; the ⌄ button hides it.</li>
        <li>The money layout reuses the same pence-first logic as <MudLink Href="components/pricepad">MudPricepad</MudLink>.</li>
        <li>It works on <strong>static-SSR pages</strong> too (it types via JavaScript, not Blazor binding) — see the <MudLink Href="features/ssr">Static SSR guide</MudLink>.</li>
        <li>While hidden it is <code class="docs-inline-code">inert</code> and <code class="docs-inline-code">aria-hidden</code> (out of the tab order); the toolbar and keys are fully labelled. See <MudLink Href="features/accessibility">Accessibility</MudLink>.</li>
    </ul>
</div>

<MudText id="parameters" Typo="Typo.h5" Class="docs-section-title">MudKeyboardHost parameters</MudText>
<ParamTable Members="HostParameters" />

<MudText id="js" Typo="Typo.h5" Class="docs-section-title">About the JavaScript</MudText>
<div class="docs-prose">
    <p>
        A browser can't report focus on arbitrary inputs to Blazor without JavaScript, so the docked
        keyboard uses one small ES module (<code class="docs-inline-code">mudKeyboard.js</code>, shipped as a
        static web asset). It does global focus capture and caret-aware insertion. All interop is confined
        to <code class="docs-inline-code">KeyboardInteropService</code>, and only primitive strings cross the
        boundary — so it stays AOT/trim-safe. The keyboard <em>core</em> remains 100% JavaScript-free.
    </p>
</div>

<div class="docs-nav-footer">
    <MudButton Href="components/pricepad" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">MudPricepad</MudButton>
    <MudButton Href="features/layouts" Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward">Layouts &amp; key tokens</MudButton>
</div>

@code {
    private string _text = string.Empty;
    private string _number = string.Empty;
    private string _money = string.Empty;
    private decimal _price;
    private double _measure;
    private int _quantity;

    private const string NumericCode = """
@* The keypad is chosen from T — no data attribute needed. (DockedKeyboard="true" because
   this site runs in OptIn mode; in the default AllInputs mode you can omit it.) *@
<MudKeyboardNumericField @bind-Value="Model.Price" T="decimal" Format="N2"
                         Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CurrencyPound"
                         DockedKeyboard="true" />   @* decimal → money keypad *@

<MudKeyboardNumericField @bind-Value="_measure" T="double" DockedKeyboard="true" /> @* double → numeric with . *@

<MudKeyboardNumericField @bind-Value="_quantity" T="int" DockedKeyboard="true" />   @* int → numeric, no . *@
""";

    private const string DemoCode = """
@* The site runs the host in OptIn mode, so fields are marked with data-mudkeyboard. *@
<MudTextField @bind-Value="_text" Label="Text (QWERTY)" Immediate="true"
              UserAttributes="@(new() { ["data-mudkeyboard"] = "true" })" />

<MudTextField @bind-Value="_number" Label="Number (numpad)" Immediate="true" InputMode="InputMode.numeric"
              UserAttributes="@(new() { ["data-mudkeyboard"] = "true" })" />

<MudTextField @bind-Value="_money" Label="Money" Immediate="true"
              UserAttributes="@(new() {
                  ["data-mudkeyboard"] = "true",
                  ["data-mudkeyboard-layout"] = "money" })" />
""";

    private const string RegisterCode = """
using MudKeyboard.Extensions;

builder.Services.AddMudServices();   // MudBlazor
builder.Services.AddMudKeyboard();   // MudKeyboard docked-keyboard services
""";

    private const string HostCode = """
<MudThemeProvider @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudKeyboardHost />   @* once, anywhere in the layout *@
""";

    private const string OptInCode = """
using MudKeyboard.Services;

// Default — attach to every editable field (opt out per-field with data-mudkeyboard-ignore)
builder.Services.AddMudKeyboard();

// Or: only attach to fields explicitly marked with data-mudkeyboard
builder.Services.AddMudKeyboard(o => o.AttachMode = KeyboardAttachMode.OptIn);
""";

    private const string AttrCode = """
@* Force a layout on a field *@
<MudTextField @bind-Value="_amount" Immediate="true"
              UserAttributes="@(new() { ["data-mudkeyboard-layout"] = "money" })" />

@* Never raise the keyboard for this field (AllInputs mode) *@
<MudTextField @bind-Value="_note" Immediate="true"
              UserAttributes="@(new() { ["data-mudkeyboard-ignore"] = "true" })" />
""";

    private static readonly IReadOnlyList<ApiMember> DataAttributes =
    [
        new("data-mudkeyboard-ignore", "—", "—", "Never raise the keyboard for this field (AllInputs mode)."),
        new("data-mudkeyboard", "—", "—", "Opt this field in when using KeyboardAttachMode.OptIn."),
        new("data-mudkeyboard-layout=\"…\"", "—", "—", "Force a layout: qwerty, numpad, decimal, or money / price. For numeric fields, MudKeyboardNumericField sets this from the bound type."),
    ];

    private static readonly IReadOnlyList<ApiMember> NumericFieldParameters =
    [
        new("Value / ValueChanged", "T", "default", "Two-way bindable numeric value (@bind-Value)."),
        new("For", "Expression<Func<T>>?", "null", "Validation expression, e.g. @(() => Model.Price)."),
        new("Format", "string?", "null", "Numeric format string applied to the value (e.g. \"N2\")."),
        new("Min / Max / Step", "T?", "null", "Forwarded to MudNumericField."),
        new("DockedKeyboard", "bool", "false", "Adds data-mudkeyboard=\"true\" (needed in OptIn mode)."),
        new("DockedKeyboardLayout", "string", "\"\"", "Overrides the auto layout (money, decimal, numpad, qwerty). Empty = resolve from T."),
    ];

    private static readonly IReadOnlyList<ApiMember> HostParameters =
    [
        new("Palette", "KeyboardPalette?", "null", "Colour overrides for the docked keyboard."),
        new("Elevation", "int", "8", "Drop-shadow elevation of the docked panel."),
        new("MinZIndex", "int", "1400", "Floor for the panel's z-index; it docks one above the top-most layer otherwise."),
        new("Style", "string?", "null", "Extra inline styles appended to the docked panel."),
        new("VisibleActions", "KeyboardAction", "All", "Which toolbar buttons render (Clear, Copy, Paste, the cursor arrows, Hide). A [Flags] set: remove buttons with & ~, or use None to drop the whole toolbar."),
        new("DisabledActions", "KeyboardAction", "None", "Which toolbar buttons render greyed-out and non-interactive. A [Flags] set; hiding via VisibleActions wins over disabling."),
    ];
}
