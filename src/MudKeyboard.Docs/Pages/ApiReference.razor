@page "/api"
@namespace MudKeyboard.Docs.Pages

<PageTitle>API reference · MudKeyboard</PageTitle>

<PageHeader Overline="Tools"
            Title="API reference"
            Lead="Every public type in the MudKeyboard library — components, models, services and the built-in layouts." />

<MudGrid Spacing="4">
    <MudItem xs="12" md="9">
        @* ---------------- Components ---------------- *@
        <h2 id="components" class="docs-section-title"><MudText Typo="Typo.h5" Style="font-weight:600;">Components</MudText></h2>

        <ApiHeading Id="mudkeyboard" Title="MudKeyboard" Namespace="MudKeyboard.Components" />
        <ParamTable Members="KeyboardParams" />

        <ApiHeading Id="mudnumpad" Title="MudNumpad" Namespace="MudKeyboard.Components" />
        <ParamTable Members="NumpadParams" />

        <ApiHeading Id="mudpricepad" Title="MudPricepad" Namespace="MudKeyboard.Components" />
        <ParamTable Members="PricepadParams" />

        <ApiHeading Id="mudkeyboardhost" Title="MudKeyboardHost" Namespace="MudKeyboard.Components" />
        <ParamTable Members="HostParams" />

        @* ---------------- Models ---------------- *@
        <h2 id="models" class="docs-section-title"><MudText Typo="Typo.h5" Style="font-weight:600;">Models</MudText></h2>

        <ApiHeading Id="keyboardlayout" Title="KeyboardLayout" Namespace="MudKeyboard.Models — sealed record" />
        <ParamTable Members="LayoutMembers" NameHeader="Member" />

        <ApiHeading Id="keyboardkey" Title="KeyboardKey" Namespace="MudKeyboard.Models — sealed record" />
        <ParamTable Members="KeyMembers" NameHeader="Member" />

        <ApiHeading Id="keyboardvariant" Title="KeyboardVariant" Namespace="MudKeyboard.Models — enum" />
        <ParamTable Members="VariantMembers" NameHeader="Value" ShowDefault="false" />

        <ApiHeading Id="keyboardaction" Title="KeyboardAction" Namespace="MudKeyboard.Models — [Flags] enum" />
        <div class="docs-prose"><p>The docked keyboard's toolbar buttons, as a <code class="docs-inline-code">[Flags]</code> set. Drives <code class="docs-inline-code">MudKeyboardHost.VisibleActions</code> and <code class="docs-inline-code">DisabledActions</code>. Combine with <code class="docs-inline-code">|</code>; remove with <code class="docs-inline-code">&amp; ~</code>.</p></div>
        <ParamTable Members="ActionMembers" NameHeader="Value" ShowDefault="false" />

        <ApiHeading Id="keyboardpalette" Title="KeyboardPalette" Namespace="MudKeyboard.Models — sealed record" />
        <ParamTable Members="PaletteMembers" NameHeader="Member" />

        <ApiHeading Id="keyboardinput" Title="KeyboardInput / KeyboardInputKind" Namespace="MudKeyboard.Models" />
        <ParamTable Members="InputMembers" NameHeader="Member" />

        <ApiHeading Id="keytokens" Title="KeyTokens" Namespace="MudKeyboard.Models — static class" />
        <ParamTable Members="TokenMembers" NameHeader="Constant / method" ShowDefault="false" />

        @* ---------------- Services ---------------- *@
        <h2 id="services" class="docs-section-title"><MudText Typo="Typo.h5" Style="font-weight:600;">Services &amp; setup</MudText></h2>

        <ApiHeading Id="addmudkeyboard" Title="AddMudKeyboard()" Namespace="MudKeyboard.Extensions — IServiceCollection extension" />
        <div class="docs-prose"><p>Registers the services needed by <code class="docs-inline-code">MudKeyboardHost</code>. Call once in <code class="docs-inline-code">Program.cs</code>; not required for the inline components.</p></div>
        <CodeBlock Language="csharp" Code="@AddCode" />

        <ApiHeading Id="mudkeyboardoptions" Title="MudKeyboardOptions" Namespace="MudKeyboard.Services" />
        <ParamTable Members="OptionMembers" NameHeader="Member" />

        <ApiHeading Id="keyboardattachmode" Title="KeyboardAttachMode" Namespace="MudKeyboard.Services — enum" />
        <ParamTable Members="AttachMembers" NameHeader="Value" ShowDefault="false" />

        <ApiHeading Id="keyboardinteropservice" Title="KeyboardInteropService" Namespace="MudKeyboard.Services — scoped service" />
        <div class="docs-prose"><p>The single place that performs JS interop for the docked keyboard. Used internally by <code class="docs-inline-code">MudKeyboardHost</code>; you rarely call it directly. Key members:</p></div>
        <ParamTable Members="InteropMembers" NameHeader="Member" ShowDefault="false" />

        @* ---------------- Layouts ---------------- *@
        <h2 id="layouts" class="docs-section-title"><MudText Typo="Typo.h5" Style="font-weight:600;">Layouts</MudText></h2>

        <ApiHeading Id="layoutlibrary" Title="LayoutLibrary" Namespace="MudKeyboard.Layouts — static class" />
        <ParamTable Members="LibraryMembers" NameHeader="Member" ShowDefault="false" />

        <div class="docs-nav-footer">
            <MudButton Href="playground" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">Playground</MudButton>
            <MudButton Href="" Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.Home">Home</MudButton>
        </div>
    </MudItem>

    <MudItem xs="12" md="3" Class="d-none d-md-flex">
        <MudPaper Outlined="true" Class="pa-3" Style="border-radius:12px;position:sticky;top:88px;width:100%;align-self:flex-start;">
            <MudText Typo="Typo.overline" Color="Color.Primary">On this page</MudText>
            <div class="d-flex flex-column" style="gap:0.15rem;">
                @foreach (var (anchor, label, indent) in Toc)
                {
                    <MudLink Href="@($"api#{anchor}")" Typo="Typo.body2" Color="Color.Inherit" Style="@($"padding-left:{indent}rem;")">@label</MudLink>
                }
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

